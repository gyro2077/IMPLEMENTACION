# Puertos publicados en host
TARGET_APP_PORT=8081
EVIDENCE_SERVER_PORT=8082
APP_DB_PORT=5433
METADATA_DB_PORT=5434

# Credenciales PostgreSQL app DB
APP_DB_NAME=target_app_db
APP_DB_USER=target_user
APP_DB_PASSWORD=target_password

# Credenciales PostgreSQL metadata DB
META_DB_NAME=evidence_meta_db
META_DB_USER=evidence_user
META_DB_PASSWORD=evidence_password

# Perfil Spring
SPRING_PROFILES_ACTIVE=docker
